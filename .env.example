# Telegram Bot Token from BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Remnawave Panel Base URL (with https://)
REMNAWAVE_API_URL=https://panel.yourdomain.com

# X-Api-Key, сгенерированный в самой панели Remnawave (Admin -> System -> API Tokens)
REMNAWAVE_X_API_KEY=eyJhbGciOi...

# --- НАСТРОЙКИ АДМИНА ---
# ID администраторов через запятую (например, 12345678,87654321). Узнать ID можно у бота @userinfobot
ADMIN_TELEGRAM_IDS=

TRAFFILK_API_URL=http://your-traffilk-url
TRAFFILK_API_KEY=trfk_your_api_key
