# Telegram Bot Token from BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Remnawave Panel Base URL (with https://)
REMNAWAVE_API_URL=https://panel.yourdomain.com

# X-Api-Key, сгенерированный в самой панели Remnawave (Admin -> System -> API Tokens)
REMNAWAVE_X_API_KEY=eyJhbGciOi...

# --- НАСТРОЙКИ АДМИНА ---
# ID администраторов через запятую (например, 12345678,87654321). Узнать ID можно у бота @userinfobot
ADMIN_TELEGRAM_IDS=

# --- НАСТРОЙКИ УВЕДОМЛЕНИЙ ОБ ОПЛАТЕ (Опционально) ---
# День месяца, когда нужно отправлять уведомление (от 1 до 31). Установите 0, чтобы отключить.
PAYMENT_NOTIFICATION_DAY=0
# Время отправки уведомления по серверному времени (например, 10:00 или 18:30)
PAYMENT_NOTIFICATION_TIME=10:00
# Текст сообщения
PAYMENT_NOTIFICATION_MESSAGE=Пожалуйста, оплатите подписку на VPN, иначе доступ будет приостановлен.
